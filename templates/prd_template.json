{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "产品需求文档 JSON 模板",
  "description": "用于创建结构化 PRD 的模板",
  "type": "object",
  "required": ["meta", "product", "features"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["id", "title", "version", "status"],
      "properties": {
        "id": {
          "type": "string",
          "description": "文档唯一标识，格式：PRD-XXX"
        },
        "title": {
          "type": "string",
          "description": "文档标题"
        },
        "version": {
          "type": "string",
          "description": "文档版本，遵循语义化版本"
        },
        "status": {
          "type": "string",
          "enum": ["draft", "review", "approved", "archived"],
          "description": "文档状态"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "创建时间（ISO8601 格式）"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "更新时间"
        },
        "author": {
          "type": "string",
          "description": "作者姓名"
        },
        "reviewers": {
          "type": "array",
          "items": {"type": "string"},
          "description": "评审人列表"
        },
        "relatedDocs": {
          "type": "array",
          "items": {"type": "string"},
          "description": "关联文档路径列表"
        }
      }
    },
    "product": {
      "type": "object",
      "required": ["name", "positioning"],
      "properties": {
        "name": {"type": "string"},
        "positioning": {"type": "string"},
        "targetUsers": {
          "type": "array",
          "items": {"type": "string"}
        },
        "goals": {
          "type": "array",
          "items": {"type": "string"}
        },
        "platforms": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "priority", "status"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "priority": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "status": {
            "type": "string",
            "enum": ["todo", "in_progress", "done", "blocked"]
          },
          "assignee": {"type": ["string", "null"]},
          "estimatedDays": {"type": "number"},
          "dependencies": {
            "type": "array",
            "items": {"type": "string"}
          },
          "acceptanceCriteria": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "timeline": {
      "type": "object",
      "properties": {
        "start": {"type": "string", "format": "date"},
        "end": {"type": "string", "format": "date"},
        "milestones": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "date": {"type": "string", "format": "date"},
              "event": {"type": "string"},
              "status": {"type": "string"}
            }
          }
        }
      }
    },
    "kpis": {
      "type": "object",
      "description": "关键绩效指标，可分组（user/game/business）"
    },
    "techStack": {
      "type": "object",
      "description": "技术栈选型"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": {"type": "string"},
          "description": {"type": "string"},
          "severity": {"type": "string"},
          "mitigation": {"type": "string"}
        }
      }
    },
    "competitors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "url": {"type": "string"},
          "strengths": {"type": "array"},
          "weaknesses": {"type": "array"}
        }
      }
    },
    "team": {
      "type": "object",
      "description": "团队配置，角色 → 人数"
    },
    "versions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "version": {"type": "string"},
          "name": {"type": "string"},
          "features": {"type": "array"},
          "targetDate": {"type": "string"}
        }
      }
    }
  }
}
